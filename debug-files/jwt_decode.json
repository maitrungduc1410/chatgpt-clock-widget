{
  "widget": {
    "type": "Card",
    "padding": {
      "left": 6,
      "right": 4,
      "y": 5
    },
    "background": {
      "light": "#1c1c1c",
      "dark": "#1c1c1c"
    },
    "theme": "dark",
    "children": [
      {
        "type": "Show",
        "$when": "state.time_format == '12h'",
        "children": [
          {
            "type": "RunInterval",
            "interval": 1000,
            "leadingTick": true,
            "$maxTicks": "state.fixed_tick == null ? null : 1",
            "$onTickAction": "{\n        \"patchState\": [\n          set(\"time_label\", slice(\"\" + (((int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 3600000) % 24 + 11) % 12) + 1), -2) + \":\" + slice(\"0\" + (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 60000) % 60), -2) + \" \" + ((int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 3600000) % 24) >= 12 ? \"PM\" : \"AM\")),\n          set(\"second_angle\", (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 1000) % 60) * 6),\n          set(\"minute_angle\", (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 60000) % 60) * 6 + (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 1000) % 60) * 0.1),\n          set(\"hour_angle\", (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 3600000) % 12) * 30 + (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 60000) % 60) * 0.5),\n          set(\"second_transform\", \"rotate(\" + ((int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 1000) % 60) * 6) + \"deg)\"),\n          set(\"minute_transform\", \"rotate(\" + ((int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 60000) % 60) * 6 + (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 1000) % 60) * 0.1) + \"deg)\"),\n          set(\"hour_transform\", \"rotate(\" + ((int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 3600000) % 12) * 30 + (int(((state.fixed_tick != null ? state.fixed_tick : tick.now) + 1000 + state.tz_offset_minutes * 60000) / 60000) % 60) * 0.5) + \"deg)\")\n        ]\n      }"
          }
        ]
      },
